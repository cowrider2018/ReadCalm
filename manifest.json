{
  "manifest_version": 3,
  "name": "Universal Reading Theme",
  "version": "1.0.0",
  "description": "Unify fonts, background and text colors across every website for comfortable reading. Warm cream + terracotta reading theme with the Charter serif font.",
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/loader.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/page/popup-guard.js"
      ],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    }
  ],
  "action": {
    "default_title": "Universal Reading Theme",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/main.js",
        "src/content/settings-manager.js",
        "src/content/domain-manager.js",
        "src/content/theme-engine.js",
        "src/content/ad/ad-guard.js",
        "src/content/ad/element-blocker.js",
        "src/content/ad/overlay-blocker.js",
        "src/content/ad/hard-blocker.js",
        "src/content/ad/scroll-lock.js",
        "src/content/ad/popup-blocker.js",
        "src/content/ad/cosmetic-blocker.js",
        "src/shared/defaults.js",
        "src/shared/ad-rules.js",
        "src/shared/color-utils.js",
        "src/shared/logger.js",
        "assets/fonts/XCharter-Roman.woff2",
      "assets/fonts/XCharter-Italic.woff2",
      "assets/fonts/XCharter-Bold.woff2",
      "assets/fonts/XCharter-BoldItalic.woff2"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_2",
        "enabled": true,
        "path": "rules/declarative/ruleset_2/ruleset_2.json"
      },
      {
        "id": "ruleset_3",
        "enabled": true,
        "path": "rules/declarative/ruleset_3/ruleset_3.json"
      },
      {
        "id": "ruleset_224",
        "enabled": true,
        "path": "rules/declarative/ruleset_224/ruleset_224.json"
      },
      {
        "id": "ruleset_18",
        "enabled": true,
        "path": "rules/declarative/ruleset_18/ruleset_18.json"
      },
      {
        "id": "ruleset_19",
        "enabled": true,
        "path": "rules/declarative/ruleset_19/ruleset_19.json"
      },
      {
        "id": "ruleset_21",
        "enabled": true,
        "path": "rules/declarative/ruleset_21/ruleset_21.json"
      }
    ]
  }
}
